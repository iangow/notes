@article{Burt:2000tm,
	abstract = {The double blind, randomized trial is now accepted as the most rigorous design for clinical research. While the concept of double blinding seems to be well understood, randomization is increasingly and erroneously being confused and credited with a power that it does not possess. Confusion arises as to whether it is the patient or the treatment that is randomized and the technique is credited with ensuring equal distribution of demographic variations and confounding factors between the treatment groups. When an imbalance of these occurs there is a tendency to consider that the randomization `failed'and that therefore the study is of no scientific value. This paper clarifies the role and purpose of randomization and discusses its function and limitations.},
	author = {Burt, R. A. P.},
	date = {2000/12/01},
	date-added = {2022-06-13 11:20:18 -0400},
