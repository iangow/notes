@article{Chen:2018wh,
	abstract = {ABSTRACT We analyze a procedure common in empirical accounting and finance research where researchers use ordinary least squares to decompose a dependent variable into its predicted and residual components and use the residuals as the dependent variable in a second regression. This two-step procedure is used to examine determinants of constructs such as discretionary accruals, real activities management, discretionary book-tax differences, and abnormal investment. We show that the typical implementation of this procedure generates biased coefficients and standard errors that can lead to incorrect inferences, with both Type I and Type II errors. We further show that the magnitude of the bias in coefficients and standard errors is a function of the correlations between model regressors. We illustrate the potential magnitude of the bias in accounting research in four commonly used settings. Our results indicate significant bias in many of these settings. We offer three solutions to avoid the bias.},
	author = {Chen, Wei and Hribar, Paul and Melessa, Samuel},
	date-added = {2023-01-25 15:51:09 -0500},
	date-modified = {2023-01-31 11:01:50 -0500},
	doi = {10.1111/j.1540-6261.2008.01391.x},
	eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1111/1475-679X.12195},
	journal = {Journal of Accounting Research},
	keywords = {C18, G10, G30, M40, M41, two-stage, residuals, coefficient bias, discretionary accruals, real earnings management},
	number = {3},
	pages = {751-796},
	title = {Incorrect Inferences When Using Residuals as Dependent Variables},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/1475-679X.12195},
	volume = {56},
	year = {2018},
	bdsk-url-1 = {https://onlinelibrary.wiley.com/doi/abs/10.1111/1475-679X.12195},
	bdsk-url-2 = {https://doi.org/10.1111/1475-679X.12195}}

@article{Chen:2019wo,
	abstract = {We study whether, and more importantly, through what mechanisms, quasi-indexers affect portfolio firms' tax planning by employing the discontinuity in quasi-indexer ownership around the Russell 1000/2000 index cutoff. Using a regression discontinuity design, we find that higher quasi-indexer ownership leads to greater tax saving. With respect to the mechanisms, we find that the greater tax saving is a result of a focus on improved overall firm performance, not a specific focus on improved tax planning. We further find that the documented tax saving effect is partially due to quasi-indexers' influences on executive equity incentives, corporate governance, and information environment.},
	author = {Chen, Shuping and Huang, Ying and Li, Ningzhong and Shevlin, Terry},
	date-added = {2023-01-25 15:51:09 -0500},
	date-modified = {2023-01-31 11:02:22 -0500},
