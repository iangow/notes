@article{Chava:2008tf,
	abstract = {ABSTRACT We identify a specific channel (debt covenants) and the corresponding mechanism (transfer of control rights) through which financing frictions impact corporate investment. Using a regression discontinuity design, we show that capital investment declines sharply following a financial covenant violation, when creditors use the threat of accelerating the loan to intervene in management. Further, the reduction in investment is concentrated in situations in which agency and information problems are relatively more severe, highlighting how the state-contingent allocation of control rights can help mitigate investment distortions arising from financing frictions.},
	author = {Chava, Sudheer and Roberts, Michael R.},
	date-added = {2023-01-25 15:51:09 -0500},
	date-modified = {2023-01-31 11:00:59 -0500},
	doi = {10.1111/j.1540-6261.2008.01391.x},
	eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1111/j.1540-6261.2008.01391.x},
	journal = {The Journal of Finance},
	number = {5},
	pages = {2085-2121},
	title = {How Does Financing Impact Investment? The Role of Debt Covenants},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/j.1540-6261.2008.01391.x},
	volume = {63},
	year = {2008},
	bdsk-url-1 = {https://onlinelibrary.wiley.com/doi/abs/10.1111/j.1540-6261.2008.01391.x},
