@article{Call:2018aa,
	abstract = {ABSTRACT Whistleblowers are ostensibly a valuable resource to regulators investigating securities violations, but whether there is a link between whistleblower involvement and the outcomes of enforcement actions is unclear. Using a data set of employee whistleblowing allegations obtained from the U.S. government and the universe of enforcement actions for financial misrepresentation, we find that whistleblower involvement is associated with higher monetary penalties for targeted firms and employees and with longer prison sentences for culpable executives. We also find that regulators more quickly begin enforcement proceedings when whistleblowers are involved. Our findings suggest that whistleblowers are a valuable source of information for regulators who investigate and prosecute financial misrepresentation.},
	author = {Call, Andrew C. and Martin, Gerald S. and Sharp, Nathan Y. and Wilde, Jaron H.},
	date-added = {2023-10-30 09:56:55 -0400},
	date-modified = {2023-10-30 09:56:55 -0400},
	doi = {10.1111/1475-679X.12177},
	eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1111/1475-679X.12177},
	journal = {Journal of Accounting Research},
	keywords = {G38, K22, K42, M40, M41, M48, whistleblowers, enforcement actions, fraud, penalties, financial reporting, Securities and Exchange Commission},
	number = {1},
	pages = {123-171},
	title = {Whistleblowers and Outcomes of Financial Misrepresentation Enforcement Actions},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/1475-679X.12177},
	volume = {56},
	year = {2018},
