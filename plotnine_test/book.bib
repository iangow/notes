	doi = {10.1093/restud/rdr043},
	journal = {The Review of Economic Studies},
	month = jan,
	number = {3},
	pages = {933--959},
	rating = {0},
	read = {Yes},
	title = {Optimal Bandwidth Choice for the Regression Discontinuity Estimator},
	url = {http://restud.oxfordjournals.org/content/79/3/933.abstract},
