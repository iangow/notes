@article{Nichols:2004tb,
	abstract = {{An extensive body of academic research in accounting develops theory and empirical evidence on the relation between earnings information and stock returns. This literature provides important insights for understanding the relevance of financial reporting. In this article, we summarize the theory and evidence on how accounting earnings information relates to firms' stock returns, particularly for the benefit of students, practitioners, and others who may not yet have been exposed to this literature. In addition, we present new empirical evidence on the relation between earnings and returns by replicating and extending three classic studies using data from 1988 through 2002. Specifically, we first demonstrate the relation between earnings changes and stock returns, replicating Ball and Brown (1968), and we compare that relation to the relation between changes in cash flows from operations and stock returns. Second, we demonstrate the impact of earnings persistence on stock returns, extending findings from studies such as Kormendi and Lipe (1987), and highlighting the effects of differences in persistence across earnings increases and decreases. Third, we provide evidence to assess the efficiency with which the capital markets impound quarterly earnings information into share prices, showing that the post‐earnings‐announcement‐drift results of Bernard and Thomas (1989) extend to recent data.}},
	author = {Nichols, D. Craig and Wahlen, James M.},
	date-added = {2023-01-25 16:12:11 -0500},
	date-modified = {2024-04-28 15:25:52 -0400},
	doi = {10.2308/acch.2004.18.4.263},
	eprint = {https://meridian.allenpress.com/accounting-horizons/article-pdf/18/4/263/1345011/acch\_2004\_18\_4\_263.pdf},
	issn = {0888-7993},
	journal = {Accounting Horizons},
	month = {12},
	number = {4},
	pages = {263-286},
	title = {How Do Earnings Numbers Relate to Stock Returns? A Review of Classic Accounting Research with Updated Evidence},
	url = {https://doi.org/10.2308/acch.2004.18.4.263},
	volume = {18},
	year = {2004},
	bdsk-url-1 = {https://doi.org/10.2308/acch.2004.18.4.263}}

